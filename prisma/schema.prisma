// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
  // Motor como PROCESSO SEPARADO (não embutido no Node): o gerenciador da
  // Hostinger clona o processo Node (fork) e o motor embutido (library) morre
  // no clone — "PANIC: timer has gone away". O binário é imune ao fork.
  engineType      = "binary"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ===================================================
// AUTH (NextAuth tables)
// ===================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?   @db.Text
  passwordHash  String?
  role          UserRole  @default(VISITOR)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownedBusinesses Business[]
  accounts        Account[]
  sessions        Session[]
  claimRequests   ClaimRequest[]
  authTokens      AuthToken[]
}

enum UserRole {
  VISITOR
  ADVERTISER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuthToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  CLAIM_VERIFICATION
}

// ===================================================
// BUSINESS
// ===================================================

model Business {
  id                String         @id @default(cuid())
  placeId           String?        @unique
  slug              String         @unique
  handle            String?        @unique   // slug curto/vanity (ex.: /arte-e-tradicao) — perk de plano pago
  name              String
  categoryId        String
  description       String?        @db.Text
  address           String
  neighborhood      String
  city              String         @default("Brasília")
  state             String         @default("DF")
  latitude          Float
  longitude         Float
  phone             String?
  whatsapp          String?
  website           String? @db.Text
  instagram         String?
  facebook          String? @db.Text
  linkedin          String? @db.Text
  youtube           String? @db.Text
  googleRating      Float?
  googleRatingCount Int?
  openingHours      Json?
  reviews           Json?            // top reviews do Google (tier pago)
  status            BusinessStatus @default(IMPORTED)
  plan              Plan           @default(FREE)
  planExpiresAt     DateTime?
  planIsCourtesy    Boolean        @default(false)  // plano ativo é cortesia (não conta como receita)
  ownerId           String?
  storeWhatsappMessage String?     @db.Text  // mensagem padrão da vitrine (WhatsApp)
  storeCoverUrl     String?        @db.Text   // foto de capa da loja (hero) — escolhida pelo lojista
  storeTagline      String?                   // slogan/frase de destaque da loja
  logoUrl           String?        @db.Text   // logo da empresa (curada pelo admin) — usada no cartão/display

  category       Category        @relation(fields: [categoryId], references: [id])
  owner          User?           @relation(fields: [ownerId], references: [id])
  photos         Photo[]
  products       Product[]
  views          BusinessView[]
  whatsappClicks WhatsappClick[]
  claimRequests  ClaimRequest[]

  importedAt   DateTime @default(now())
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([categoryId])
  @@index([ownerId])
  @@index([neighborhood])
  @@index([plan])
  @@index([status])
}

enum BusinessStatus {
  IMPORTED
  CLAIMED
  PENDING_REVIEW
  SUSPENDED
}

enum Plan {
  FREE
  VISIBILITY
  PREMIUM
}

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  iconName    String?
  description String?
  parentId    String?
  order       Int     @default(0)

  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children   Category[] @relation("CategoryHierarchy")
  businesses Business[]

  @@index([parentId])
}

model Photo {
  id         String      @id @default(cuid())
  businessId String
  url        String      @db.Text
  width      Int?
  height     Int?
  source     PhotoSource
  order      Int         @default(0)
  createdAt  DateTime    @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

enum PhotoSource {
  GOOGLE_PLACES
  OWNER_UPLOAD
  OPERATOR_UPLOAD
}

// ===================================================
// CLAIMS
// ===================================================

model ClaimRequest {
  id          String      @id @default(cuid())
  businessId  String
  userId      String
  status      ClaimStatus @default(PENDING)
  message     String?     @db.Text
  documentUrl String?
  createdAt   DateTime    @default(now())
  reviewedAt  DateTime?
  reviewerId  String?

  business Business @relation(fields: [businessId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([status])
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

// ===================================================
// METRICS
// ===================================================

model BusinessView {
  id         String   @id @default(cuid())
  businessId String
  date       DateTime @default(now()) @db.Date
  count      Int      @default(1)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId])
  @@index([date])
}

model WhatsappClick {
  id         String   @id @default(cuid())
  businessId String
  date       DateTime @default(now()) @db.Date
  count      Int      @default(1)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId])
}

// ===================================================
// BILLING
// ===================================================

model Subscription {
  id              String    @id @default(cuid())
  businessId      String    @unique
  plan            Plan
  status          SubStatus
  asaasCustomerId String
  asaasSubId      String?
  startedAt       DateTime  @default(now())
  expiresAt       DateTime?
  canceledAt      DateTime?

  @@index([status])
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

// ===================================================
// AUDIT LOG
// ===================================================

// Presença/analytics leve do site — 1 linha por visitante (cookie anônimo).
// Permite "online agora" e "visitantes ativos hoje/7d/30d" sem depender de terceiros.
model Presence {
  visitorId String   @id
  firstSeen DateTime @default(now())
  lastSeen  DateTime @updatedAt
  hits      Int      @default(1)

  @@index([lastSeen])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entity     String
  entityId   String
  businessId String?  // lojista alvo da ação (quando aplicável) — para filtro/histórico
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([businessId])
  @@index([createdAt])
}

// ===================================================
// API USAGE — monitoração de custo da Google Places API
// ===================================================

model ApiUsage {
  id        String   @id @default(cuid())
  kind      String   // NEARBY | TEXT | PHOTO | DETAILS
  units     Int      @default(1)   // nº de requisições
  results   Int      @default(0)   // nº de negócios retornados (p/ custo por negócio)
  costUsd   Float    @default(0)
  query     String?  @db.Text       // tipo ou termo pesquisado
  createdAt DateTime @default(now())

  @@index([kind])
  @@index([createdAt])
}

// ===================================================
// VITRINE DE PRODUTOS (mini-loja do anunciante)
// ===================================================

model Product {
  id          String           @id @default(cuid())
  businessId  String
  name        String
  description String?          @db.Text
  categoria   String?          // tipo/categoria do produto (texto livre)
  priceMode   ProductPriceMode @default(FIXED)
  priceCents  Int?             // preço em centavos; null se ON_REQUEST
  promoPriceCents Int?         // preço promocional (centavos); se preenchido → "Oferta"
  images      Json?            // até 4 URLs (Cloudinary)
  variations  Json?            // ex: [{ "nome": "Tamanho", "opcoes": ["P","M","G"] }]
  soldOut     Boolean          @default(false)
  active      Boolean          @default(true)
  featured    Boolean          @default(false)  // produto em destaque na loja
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

enum ProductPriceMode {
  FIXED       // "R$ 30,00"
  FROM        // "A partir de R$ 30,00"
  ON_REQUEST  // "Sob consulta"
}

// ===================================================
// PAGAMENTO MANUAL (PIX + Mercado Pago)
// ===================================================

model PaymentConfig {
  id              String   @id @default("default")
  pixKey          String?
  pixHolderName   String?
  pixCopyPaste    String?  @db.Text  // PIX copia-e-cola (BR Code) → vira QR
  mercadoPagoLink String?  @db.Text
  instructions    String?  @db.Text
  visibilityCents Int      @default(7900)   // preço do plano Visibilidade (centavos)
  premiumCents    Int      @default(19700)  // preço do plano Premium (centavos)
  updatedAt       DateTime @updatedAt
}

model PaymentClaim {
  id          String    @id @default(cuid())
  businessId  String
  userId      String
  plan        Plan
  method      String    // PIX | MERCADO_PAGO
  months      Int       @default(1)
  amountCents Int       @default(0)
  status      String    @default("PENDING") // PENDING | CONFIRMED | REJECTED
  note        String?   @db.Text
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?
  reviewerId  String?

  @@index([status])
  @@index([businessId])
}

// Configuração de cada plano — controlada 100% pelo admin no painel.
// Preço, limites e recursos (feature flags) ficam aqui; plans.ts é só fallback/seed.
model PlanConfig {
  plan         Plan     @id              // FREE | VISIBILITY | PREMIUM
  label        String                    // nome exibido (editável)
  active       Boolean  @default(true)   // se o plano aparece para escolha
  order        Int      @default(0)      // ordem de exibição
  priceCents   Int      @default(0)      // preço mensal (centavos)
  productLimit Int      @default(2)      // máximo de produtos na vitrine
  photoLimit   Int      @default(3)      // máximo de fotos do perfil
  features     Json                      // { promocoes, loja, eventos, metricas, destaque, redesSociais, selo }
  mercadoPagoLink String? @db.Text       // link de cobrança do Mercado Pago deste plano (valor fixo mensal)
  updatedAt    DateTime @updatedAt
}

// ===================================================
// CONTEÚDO — Notícias (admin) e Eventos (anunciante + moderação)
// ===================================================

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?   @db.Text
  content     String    @db.Text
  coverUrl    String?   @db.Text
  status      String    @default("DRAFT")   // DRAFT | PUBLISHED
  featured    Boolean   @default(false)
  authorId    String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
}

model Event {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?   @db.Text
  content       String    @db.Text
  coverUrl      String?   @db.Text
  status        String    @default("PENDING") // PENDING | PUBLISHED | REJECTED
  featured      Boolean   @default(false)
  eventDate     DateTime?
  eventLocation String?
  eventUrl      String?   @db.Text
  moderationNote String?  @db.Text            // observação do admin ao rejeitar
  businessId    String?                       // negócio do anunciante que criou
  authorId      String
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, eventDate])
  @@index([businessId])
}
